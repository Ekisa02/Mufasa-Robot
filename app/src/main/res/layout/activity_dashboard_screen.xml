<!-- File: src/main/res/layout/activity_dashboard.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_dashboard_background"
    >

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="MUFASA ROBOT"
            app:titleTextColor="@color/deep_gold"
            app:titleTextAppearance="@style/TextAppearance.MufasaRobot.Toolbar">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivNotification"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="8dp"
                    android:src="@drawable/ic_notification" />

                <TextView
                    android:id="@+id/tvNotificationBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignTop="@id/ivNotification"
                    android:layout_alignEnd="@id/ivNotification"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/badge_background"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </RelativeLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/llMainContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:animateLayoutChanges="true">

                <!-- Connection Status Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardConnection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/tvConnectionTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔌 Connection Status"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/deep_gold" />

                            <ImageView
                                android:id="@+id/ivRefreshConnection"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_refresh"
                                android:padding="4dp" />

                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/llConnectionStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:id="@+id/vStatusIndicator"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/status_indicator_connected" />

                            <TextView
                                android:id="@+id/tvConnectionText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="MT5 Connected"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/llConnectionDetails"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:visibility="visible">

                            <TextView
                                android:id="@+id/tvServer"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Server: ICMarkets-Demo"
                                android:textSize="14sp"
                                android:textColor="@color/gray" />

                            <TextView
                                android:id="@+id/tvAccount"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Account: 12345678"
                                android:textSize="14sp"
                                android:textColor="@color/gray"
                                android:gravity="end" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Bot Status Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvBotTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤖 Bot Status"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/royal_blue" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp">

                            <LinearLayout
                                android:id="@+id/llBotStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true">

                                <View
                                    android:id="@+id/vBotStatusIndicator"
                                    android:layout_width="12dp"
                                    android:layout_height="12dp"
                                    android:background="@drawable/status_indicator_active" />

                                <TextView
                                    android:id="@+id/tvBotStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Active"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/btnStartStop"
                                    android:layout_width="wrap_content"
                                    android:layout_height="40dp"
                                    android:text="STOP"
                                    android:textSize="14sp"
                                    android:backgroundTint="@color/error"
                                    app:cornerRadius="12dp" />

                            </LinearLayout>

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">

                            <TextView
                                android:id="@+id/tvStrategy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="Strategy: Scalper Pro"
                                android:textSize="14sp"
                                android:textColor="@color/gray" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tvAutoTradingLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Auto Trading"
                                    android:textSize="14sp"
                                    android:layout_marginEnd="8dp" />

                                <androidx.appcompat.widget.SwitchCompat
                                    android:id="@+id/switchAutoTrading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checked="true"
                                    android:thumbTint="@color/royal_blue"
                                    android:trackTint="@color/royal_blue_light" />

                            </LinearLayout>

                        </RelativeLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Trade Activity Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTrade"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvTradeTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 Trade Activity"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/emerald_green" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <ImageView
                                    android:id="@+id/ivAutoOpen"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_trending_up"
                                    android:tint="@color/emerald_green" />

                                <TextView
                                    android:id="@+id/tvAutoOpenLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Auto Open"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray" />

                                <TextView
                                    android:id="@+id/tvAutoOpenValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ON"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/emerald_green" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <ImageView
                                    android:id="@+id/ivAutoClose"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_trending_down"
                                    android:tint="@color/emerald_green" />

                                <TextView
                                    android:id="@+id/tvAutoCloseLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Auto Close"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray" />

                                <TextView
                                    android:id="@+id/tvAutoCloseValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ON"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/emerald_green" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="16dp"
                            android:background="@color/light_gray" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvLastTradeLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Last Trade"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray" />

                                <TextView
                                    android:id="@+id/tvLastTradeValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="14:30:22"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:id="@+id/tvPnLLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="P/L"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray" />

                                <TextView
                                    android:id="@+id/tvPnLValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+$1,250.50"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/profit_green" />

                            </LinearLayout>

                        </RelativeLayout>

                        <ProgressBar
                            android:id="@+id/progressTrade"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="12dp"
                            android:progress="70"
                            android:progressTint="@color/royal_blue"
                            android:progressBackgroundTint="@color/royal_blue_light" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Automation Controls Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAutomation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvAutomationTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔄 Automation Controls"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/sunset_orange" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp">

                            <TextView
                                android:id="@+id/tvAutoOpenLabel2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="Enable Auto Open"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchAutoOpen"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:checked="true"
                                android:thumbTint="@color/emerald_green"
                                android:trackTint="@color/emerald_green_light" />

                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="8dp"
                            android:background="@color/light_gray" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvAutoCloseLabel2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="Enable Auto Close"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchAutoClose"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:checked="true"
                                android:thumbTint="@color/emerald_green"
                                android:trackTint="@color/emerald_green_light" />

                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="8dp"
                            android:background="@color/light_gray" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvRiskLevelLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="Risk Level"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnRiskLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:layout_alignParentEnd="true"
                                android:text="MEDIUM"
                                android:textColor="@color/sunset_orange"
                                android:backgroundTint="@color/sunset_orange_light"
                                app:cornerRadius="12dp"
                                android:drawableEnd="@drawable/ic_arrow_drop_down" />

                        </RelativeLayout>

                        <Button
                            android:id="@+id/btnSaveSettings"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="16dp"
                            android:text="SAVE SETTINGS"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:backgroundTint="@color/emerald_green"
                            app:cornerRadius="16dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- User Feedback Section -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvFeedbackTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧾 Notifications"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/deep_gold" />

                        <LinearLayout
                            android:id="@+id/llFeedbacks"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical">

                            <!-- Feedback Item 1 -->
                            <LinearLayout
                                android:id="@+id/llFeedback1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/feedback_info_background"
                                android:padding="12dp">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/feedback_success_dot" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="12dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvFeedback1Message"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Bot started successfully"
                                        android:textSize="14sp"
                                        android:maxLines="2" />

                                    <TextView
                                        android:id="@+id/tvFeedback1Time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="14:30:22"
                                        android:textSize="10sp"
                                        android:textColor="@color/gray" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Feedback Item 2 -->
                            <LinearLayout
                                android:id="@+id/llFeedback2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/feedback_info_background"
                                android:padding="12dp">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/feedback_info_dot" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="12dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvFeedback2Message"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Trade opened: EURUSD"
                                        android:textSize="14sp"
                                        android:maxLines="2" />

                                    <TextView
                                        android:id="@+id/tvFeedback2Time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="14:25:22"
                                        android:textSize="10sp"
                                        android:textColor="@color/gray" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Feedback Item 3 -->
                            <LinearLayout
                                android:id="@+id/llFeedback3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:background="@drawable/feedback_info_background"
                                android:padding="12dp">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/feedback_success_dot" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="12dp"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvFeedback3Message"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Connection stable"
                                        android:textSize="14sp"
                                        android:maxLines="2" />

                                    <TextView
                                        android:id="@+id/tvFeedback3Time"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="14:20:22"
                                        android:textSize="10sp"
                                        android:textColor="@color/gray" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Space for FAB -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp" />

            </LinearLayout>

        </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRefresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_refresh"
        android:backgroundTint="@color/royal_blue"
        app:backgroundTint="@color/royal_blue"
        app:maxImageSize="24dp" />

    <!-- Snackbar container will be handled programmatically -->

