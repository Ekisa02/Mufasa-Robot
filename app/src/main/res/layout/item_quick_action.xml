<!-- File: src/main/res/layout/item_quick_action.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/quick_action_background">

    <ImageView
        android:id="@+id/ivQuickActionIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:background="@drawable/quick_action_icon_background" />

    <TextView
        android:id="@+id/tvQuickActionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="@color/royal_blue" />

</LinearLayout>